rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // App config (feature flags) - 인증된 사용자 읽기, 쓰기는 서버(admin)만
    match /app_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Daily news collection - 모두 읽기 가능
    match /daily_news/{date} {
      allow read: if true; // 누구나 읽기 가능
      allow write: if false; // 서버에서만 쓰기 (GitHub Actions)
    }

    // Daily principles (에이전트 생성) - 모두 읽기 가능
    match /daily_principles/{date} {
      allow read: if true;
      allow write: if false;
    }

    // Daily briefings - 모두 읽기 가능
    match /daily_briefings/{date} {
      allow read: if true;
      allow write: if false;
    }

    // Daily quizzes - 모두 읽기 가능
    match /daily_quizzes/{date} {
      allow read: if true;
      allow write: if false;
    }

    // Daily tools (AI 도구 추천) - 모두 읽기 가능
    match /daily_tools/{date} {
      allow read: if true;
      allow write: if false;
    }

    // Articles collection - 모두 읽기 가능
    match /articles/{articleId} {
      allow read: if true;
      allow write: if false;
    }

    // Glossary terms - 모두 읽기 가능
    match /glossary_terms/{termId} {
      allow read: if true;
      allow write: if false;
    }

    // Daily story timeline - 모두 읽기 가능
    match /daily_story_timeline/{date} {
      allow read: if true;
      allow write: if false;
    }


    // Principles collection (레거시) - 모두 읽기 가능
    match /principles/{principleId} {
      allow read: if true; // 누구나 읽기 가능
      allow write: if false; // 서버에서만 쓰기
    }

    // User feedback - 본인 데이터만 CRUD 가능
    match /user_feedback/{feedbackId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // User data - 본인만 읽기/쓰기 (업데이트 시 허용 필드 제한)
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['language', 'displayName', 'photoURL', 'email',
                     'expoPushToken', 'fcmToken', 'lastLoginAt', 'theme']);

      // User's bookmarks subcollection
      match /bookmarks/{bookmarkId} {
        allow read, write: if isOwner(userId);
      }

      // User's learning history subcollection
      match /learning_history/{historyId} {
        allow read, write: if isOwner(userId);
      }

      // User's preferences subcollection
      match /preferences/{prefId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Article views (조회수) - 누구나 읽기, 쓰기는 views 필드 +1만 허용
    match /article_views/{articleId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['views'])
                    && request.resource.data.views is int
                    && request.resource.data.views == 1;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
                    && request.resource.data.views is int
                    && request.resource.data.views == resource.data.views + 1;
    }

    // Reactions (좋아요) - 누구나 읽기, 로그인 시 쓰기 (필드 타입 + count 일관성 검증)
    match /reactions/{reactionId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['likes', 'likedBy', 'dislikes', 'dislikedBy'])
        && request.resource.data.keys().hasOnly(['likes', 'likedBy', 'dislikes', 'dislikedBy', 'contentAuthorUid'])
        && request.resource.data.likes is int
        && request.resource.data.likedBy is list
        && request.resource.data.dislikes is int
        && request.resource.data.dislikedBy is list
        && request.resource.data.likes == request.resource.data.likedBy.size()
        && request.resource.data.dislikes == request.resource.data.dislikedBy.size();
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['likes', 'likedBy', 'dislikes', 'dislikedBy', 'contentAuthorUid'])
        && request.resource.data.likes is int
        && request.resource.data.likedBy is list
        && request.resource.data.dislikes is int
        && request.resource.data.dislikedBy is list
        && request.resource.data.likes == request.resource.data.likedBy.size()
        && request.resource.data.dislikes == request.resource.data.dislikedBy.size();
    }

    // Comments (댓글) - 누구나 읽기, 루트 문서 클라이언트 쓰기 불가
    match /comments/{commentId} {
      allow read: if true;
      allow write: if false;

      match /entries/{entryId} {
        allow read: if true;
        // 생성: 본인 UID 필수 + 텍스트 길이 제한 + 허용 필드만
        allow create: if isAuthenticated()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() <= 100
          && request.resource.data.keys().hasOnly(['text', 'authorName', 'authorUid', 'createdAt', 'parentId']);
        // 본인 댓글 삭제
        allow delete: if isAuthenticated() && resource.data.authorUid == request.auth.uid;
        // 본인 댓글 수정 또는 타인 댓글 reportCount +1 (신고)
        allow update: if isAuthenticated() && (
          resource.data.authorUid == request.auth.uid ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reportCount']) &&
            request.resource.data.reportCount is int &&
            request.resource.data.reportCount == (('reportCount' in resource.data) ? resource.data.reportCount + 1 : 1)
          )
        );
      }
    }

    // Reports (댓글 신고) - 본인 신고만 읽기, 로그인 시 생성, 수정/삭제 불가
    match /reports/{reportId} {
      allow read: if isAuthenticated() && resource.data.reporterUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.reporterUid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
